<Window x:Class="SpriteForge.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SpriteForge.Gui.Views"
        xmlns:vm="clr-namespace:SpriteForge.Gui.ViewModels"
        Title="SpriteForge" Height="720" Width="1100"
        MinWidth="860" MinHeight="520"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource WindowBrush}"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Transparency checkerboard for 3D preview: 20px EditorBrush/PanelBrush squares. -->
        <DrawingBrush x:Key="CheckerBrush" Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource EditorBrush}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,20,20"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PanelBrush}">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,10,10"/>
                                <RectangleGeometry Rect="10,10,10,10"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Finer checkerboard for 2D result area: 12px squares. -->
        <DrawingBrush x:Key="CheckerBrush12" Viewport="0,0,12,12" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{StaticResource EditorBrush}">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,12,12"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="{StaticResource PanelBrush}">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,6,6"/>
                                <RectangleGeometry Rect="6,6,6,6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Soft radial vignette. -->
        <RadialGradientBrush x:Key="VignetteBrush">
            <GradientStop Offset="0.55" Color="#00000000"/>
            <GradientStop Offset="1.0"  Color="#66000000"/>
        </RadialGradientBrush>

        <!-- Flat caption buttons (46×34). -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource MenuTextBrush}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BorderStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button: red on hover. -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="{StaticResource MenuTextBrush}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource CloseHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact toolbar button used in panel header bars. -->
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <!-- Frosted corner badge chip overlaid on canvas areas. -->
        <Style x:Key="BadgeChip" TargetType="Border">
            <Setter Property="Background" Value="#D2161719"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

        <!-- Micro label (10px, SemiBold, label color) — shared by rail fields. -->
        <Style x:Key="MicroLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextLabelBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Slider row used in Camera group: label on the left, value on the right. -->
        <Style x:Key="CamSliderLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextLabelBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CamSliderValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Typography.NumeralAlignment" Value="Tabular"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ===== Title bar (34px) ===== -->
        <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- 2×2 pixel-grid icon -->
                    <Border Width="17" Height="17" CornerRadius="4" Background="{StaticResource AccentBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="7" Height="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="3" Height="3"
                                       Fill="{StaticResource OnAccentBrush}"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="0" Width="3" Height="3"
                                       Fill="{StaticResource OnAccentBrush}" Opacity="0.55"/>
                            <Rectangle Canvas.Left="0" Canvas.Top="4" Width="3" Height="3"
                                       Fill="{StaticResource OnAccentBrush}" Opacity="0.55"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="3" Height="3"
                                       Fill="{StaticResource OnAccentBrush}"/>
                        </Canvas>
                    </Border>
                    <TextBlock Text="SpriteForge" FontWeight="Bold" FontSize="12" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                    <!-- Document name: visible when a file is loaded -->
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="— "/>
                        <Run Text="{Binding DocumentName, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" ToolTip="Minimize">
                        <Path Data="M 1,8 L 11,8" StrokeThickness="1"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <Button Style="{StaticResource CaptionButton}" Click="Maximize_Click" ToolTip="Maximize">
                        <Path Data="M 1,1 L 11,1 L 11,11 L 1,11 Z" StrokeThickness="1" Fill="Transparent"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Close">
                        <Path Data="M 1,1 L 11,11 M 11,1 L 1,11" StrokeThickness="1"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Menu bar (28px) ===== -->
        <Border Grid.Row="1" Background="{StaticResource MenuBarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="9,0">
                <TextBlock Text="File"  Foreground="{StaticResource MenuTextBrush}" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Text="Edit"  Foreground="{StaticResource MenuTextBrush}" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Text="View"  Foreground="{StaticResource MenuTextBrush}" FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Text="Help"  Foreground="{StaticResource MenuTextBrush}" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ===== 4-column body ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================================
                 COL 0 — Left rail (268px)
                 MODEL panel (always active) + DIM WRAPPER (Camera + Equipment)
                 ======================================================== -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource RailBrush}"
                          BorderBrush="{StaticResource BorderSubtleBrush}"
                          BorderThickness="0,0,1,0">
                <StackPanel Margin="8">

                    <!-- MODEL group -->
                    <GroupBox Header="Model" Margin="0,0,0,8">
                        <StackPanel>
                            <!-- Mesh file -->
                            <TextBlock Text="MESH" Style="{StaticResource MicroLabel}"/>
                            <DockPanel Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Content="…" Width="28" Margin="4,0,0,0"
                                        Command="{Binding BrowseMeshCommand}" ToolTip="Browse for mesh file"/>
                                <TextBox Text="{Binding InputPath}" ToolTip="{Binding InputPath}"/>
                            </DockPanel>

                            <!-- Animation file (optional) -->
                            <TextBlock Text="ANIMATION (OPTIONAL)" Style="{StaticResource MicroLabel}"/>
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="…" Width="28" Margin="4,0,0,0"
                                        Command="{Binding BrowseAnimCommand}" ToolTip="Browse for animation file"/>
                                <TextBox Text="{Binding AnimPath}" ToolTip="{Binding AnimPath}"/>
                            </DockPanel>

                            <!-- Render px / FPS / Directions -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="RENDER PX" Style="{StaticResource MicroLabel}"/>
                                    <TextBox Text="{Binding RenderSize}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FPS" Style="{StaticResource MicroLabel}"/>
                                    <TextBox Text="{Binding Fps}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="DIRS" Style="{StaticResource MicroLabel}"/>
                                    <TextBox Text="{Binding Directions}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Load / Reload -->
                            <Button Content="Load / Reload" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding LoadCommand}"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- DIM WRAPPER: Camera + Equipment (opacity .4 + disabled when nothing loaded) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- CAMERA group (sliders) -->
                        <GroupBox Header="Camera" Margin="0,0,0,8">
                            <StackPanel>

                                <!-- Pitch slider -->
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock DockPanel.Dock="Left" Text="Pitch" Style="{StaticResource CamSliderLabel}"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding RotX, StringFormat='{}{0:F1}°'}"
                                               Style="{StaticResource CamSliderValue}"/>
                                </DockPanel>
                                <Slider Minimum="0" Maximum="90" Value="{Binding RotX}" Margin="0,0,0,8"/>

                                <!-- Yaw slider -->
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock DockPanel.Dock="Left" Text="Yaw" Style="{StaticResource CamSliderLabel}"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding RotY, StringFormat='{}{0:F0}°'}"
                                               Style="{StaticResource CamSliderValue}"/>
                                </DockPanel>
                                <Slider Minimum="0" Maximum="360" Value="{Binding RotY}" Margin="0,0,0,8"/>

                                <!-- Zoom slider -->
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock DockPanel.Dock="Left" Text="Zoom" Style="{StaticResource CamSliderLabel}"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding Zoom, StringFormat='×{0:F2}'}"
                                               Style="{StaticResource CamSliderValue}"/>
                                </DockPanel>
                                <Slider Minimum="0.25" Maximum="4.0" Value="{Binding Zoom}" Margin="0,0,0,8"/>

                                <!-- Distance slider (0 = auto-fit) -->
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock DockPanel.Dock="Left" Text="Distance" Style="{StaticResource CamSliderLabel}"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding CamDistance, StringFormat='{}{0:F1}'}"
                                               Style="{StaticResource CamSliderValue}"/>
                                </DockPanel>
                                <Slider Minimum="0" Maximum="20" Value="{Binding CamDistance}" Margin="0,0,0,10"/>

                                <!-- Divider -->
                                <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,0,0,10"/>

                                <!-- Checkboxes -->
                                <CheckBox Content="Orthographic" IsChecked="{Binding Ortho}" Margin="0,0,0,6"/>
                                <CheckBox Content="Z-up source"  IsChecked="{Binding UpAxisZ}" Margin="0,0,0,6"/>
                                <CheckBox Content="In-place (remove root motion)" IsChecked="{Binding InPlace}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- EQUIPMENT panel (UserControl) -->
                        <views:EquipmentPanel x:Name="EquipmentPanelView"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ========================================================
                 COL 1 — Center (flex): 3D preview + AnimationPanel strip
                 ======================================================== -->
            <Border Grid.Column="1"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="238"/>
                </Grid.RowDefinitions>

                <!-- 3D Preview area -->
                <Grid Grid.Row="0" ClipToBounds="True" Background="{StaticResource EditorBrush}">
                    <!-- Checkerboard + vignette -->
                    <Rectangle Fill="{StaticResource CheckerBrush}"/>
                    <Rectangle Fill="{StaticResource VignetteBrush}" IsHitTestVisible="False"/>

                    <!-- Preview header (28px overlay) -->
                    <Border VerticalAlignment="Top" Height="28"
                            Background="#E61C1D1F"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Panel.ZIndex="2">
                        <DockPanel>
                            <!-- Right: zoom controls group -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                <Button Style="{StaticResource ToolButton}" Content="−" ToolTip="Zoom out" Margin="0,0,2,0"/>
                                <Button Style="{StaticResource ToolButton}" Content="100%" ToolTip="Zoom level" MinWidth="38" Margin="0,0,2,0"/>
                                <Button Style="{StaticResource ToolButton}" Content="+" ToolTip="Zoom in" Margin="0,0,2,0"/>
                                <Button Style="{StaticResource ToolButton}" Content="Fit" ToolTip="Fit to view"/>
                            </StackPanel>
                            <!-- Left: title + clip name -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="9,0">
                                <TextBlock Text="3D PREVIEW" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource HeaderTextBrush}"/>
                                <TextBlock Text=" / " Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding AnimName}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- 3D render image (visible when model is loaded) -->
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                           Margin="20,48,20,20"
                           RenderOptions.BitmapScalingMode="NearestNeighbor">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Empty state (visible when nothing loaded) -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1.5"
                            CornerRadius="8" Background="#2D000000" Padding="28">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Cube outline icon (simple path) -->
                            <Path HorizontalAlignment="Center" Margin="0,0,0,12"
                                  Stroke="{StaticResource BorderHoverBrush}" StrokeThickness="1.4"
                                  Fill="Transparent"
                                  Data="M 16,4 L 28,10 L 28,22 L 16,28 L 4,22 L 4,10 Z M 16,4 L 16,28 M 4,10 L 28,10"/>
                            <TextBlock Text="No model loaded" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource TextLabelBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Browse and load a rigged FBX or GLB from the Model panel."
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="11.5"
                                       TextWrapping="Wrap" MaxWidth="210" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Corner badges (visible when model is loaded) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="8,36,0,0" Panel.ZIndex="1">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Style="{StaticResource BadgeChip}" Margin="0,0,4,0">
                            <TextBlock Text="{Binding RenderSize, StringFormat='{}{0} px'}"
                                       FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <Border Style="{StaticResource BadgeChip}">
                            <TextBlock Text="{Binding Directions, StringFormat='{}{0} dir'}"
                                       FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,36,8,0" Panel.ZIndex="1">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource BadgeChip}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding AnimName, StringFormat='Clip: {0}'}"
                                   FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </Grid>

                <!-- ANIMATION strip (238px) -->
                <views:AnimationPanel x:Name="AnimationPanelView" Grid.Row="1"/>
            </Grid>
            </Border>

            <!-- ========================================================
                 COL 2 — Right rail (360px): 2D result + OutputPanel strip
                 ======================================================== -->
            <GridSplitter Grid.Column="2"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderSubtleBrush}"
                          ShowsPreview="True"/>

            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="238"/>
                </Grid.RowDefinitions>

                <!-- 2D Result area (animation player) -->
                <views:ResultPanel x:Name="ResultPanelView" Grid.Row="0"/>
                <Grid Grid.Row="0" ClipToBounds="True" Background="{StaticResource EditorBrush}" Visibility="Collapsed">
                    <Rectangle Fill="{StaticResource CheckerBrush12}"/>
                    <Rectangle Fill="{StaticResource VignetteBrush}" IsHitTestVisible="False"/>

                    <!-- Result header (28px overlay) -->
                    <Border VerticalAlignment="Top" Height="28"
                            Background="#E61C1D1F"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Panel.ZIndex="2">
                        <DockPanel Margin="9,0">
                            <!-- Right: placeholder zoom controls -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                <Button Style="{StaticResource ToolButton}" Content="−" ToolTip="Zoom out" Margin="0,0,2,0"/>
                                <Button Style="{StaticResource ToolButton}" Content="100%" MinWidth="38" Margin="0,0,2,0"/>
                                <Button Style="{StaticResource ToolButton}" Content="+" ToolTip="Zoom in"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="2D RESULT" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource HeaderTextBrush}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Empty state: model not loaded -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1.5"
                            CornerRadius="8" Background="#2D000000" Padding="28">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="No output yet" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource TextLabelBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Generate a sprite sheet to preview it here."
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="11.5"
                                       TextWrapping="Wrap" MaxWidth="200" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sprite preview: model loaded, no sheet yet -->
                    <Image Margin="20,48,20,20"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Uniform"
                           Source="{Binding PreviewImage}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <!-- Show when loaded AND no sheet -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsLoaded}" Value="True"/>
                                            <Condition Binding="{Binding HasSheet}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- Sheet map: shown once a sheet has been generated -->
                    <Image Margin="20,48,20,20"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Uniform"
                           Source="{Binding SheetPreviewImage}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSheet}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <!-- State badge (bottom-right): "SPRITE PREVIEW" or "SHEET MAP" -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,8,8" Panel.ZIndex="1">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource BadgeChip}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10.5" Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="SPRITE PREVIEW"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSheet}" Value="True">
                                            <Setter Property="Text" Value="SHEET MAP"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>

                <!-- OUTPUT strip (238px) -->
                <views:OutputPanel x:Name="OutputPanelView" Grid.Row="1"/>
            </Grid>
        </Grid>

        <!-- ===== Status bar (26px) ===== -->
        <Border Grid.Row="3" Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="9,0">
                <!-- Right: compact settings summary -->
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11.5">
                    <Run Text="{Binding Directions, Mode=OneWay}"/>
                    <Run Text=" dir · "/>
                    <Run Text="{Binding RenderSize, Mode=OneWay}"/>
                    <Run Text=" px · "/>
                    <Run Text="{Binding Fps, Mode=OneWay}"/>
                    <Run Text=" fps"/>
                </TextBlock>
                <!-- Left: status dot + text -->
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                            <Style.Triggers>
                                <!-- Empty state: muted -->
                                <DataTrigger Binding="{Binding IsLoaded}" Value="False">
                                    <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                                </DataTrigger>
                                <!-- Sheet generated: success green (overrides loaded accent) -->
                                <DataTrigger Binding="{Binding HasSheet}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           Foreground="{StaticResource MenuTextBrush}" FontSize="11.5"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
