<Application x:Class="SpriteForge.Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:SpriteForge.Gui.Mvvm"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- App-wide converters (panels also declare their own BoolToVis locally; these are shared by MainWindow). -->
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <mvvm:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
